# ── Smart City Streaming — Environment Variables ──────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OpenWeather API (https://openweathermap.org/api — free tier works)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# AWS credentials (configure via IAM user with S3FullAccess + GlueConsoleFullAccess)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# S3 bucket name (must exist before running Spark processor)
S3_BUCKET_NAME=smart-city-streaming-bucket

# Redshift (optional — only needed for Spectrum queries)
REDSHIFT_CLUSTER_ID=smart-city-cluster
REDSHIFT_IAM_ROLE=arn:aws:iam::ACCOUNT_ID:role/RedshiftRole
